# --- Backend ---
# SQLite veritabanı dosyasının yolu (backend klasörüne göre)
DATABASE_URL=sqlite:///./crm.db

# CSV dosyalarının bulunduğu klasör
DATA_DIR=../data

# API sunucu ayarları
API_HOST=127.0.0.1
API_PORT=8000

# CORS için izin verilen frontend adresi
FRONTEND_ORIGIN=http://localhost:5173

# --- ikas GraphQL (İLERİDE — şimdilik boş bırak) ---
IKAS_API_URL=
IKAS_CLIENT_ID=
IKAS_CLIENT_SECRET=

# --- Frontend (Vite — VITE_ önekli olmalı) ---
VITE_API_BASE_URL=http://127.0.0.1:8000
